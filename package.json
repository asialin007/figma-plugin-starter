{
  "name": "batch-rename-figma-plugin",
  "version": "1.0.0",
  "description": "批量重命名 Figma 图层，支持前缀、后缀、自动编号及专业切图命名规范",
  "author": "Asialin",
  "license": "MIT",
  "dependencies": {
    "@create-figma-plugin/ui": "^4.0.3",
    "@create-figma-plugin/utilities": "^4.0.3",
    "preact": ">=10",
    "prismjs": "1.29.0",
    "react-simple-code-editor": "0.13.1"
  },
  "devDependencies": {
    "@create-figma-plugin/build": "^4.0.3",
    "@create-figma-plugin/tsconfig": "^4.0.3",
    "@figma/plugin-typings": "1.109.0",
    "@types/prismjs": "1.26.3",
    "typescript": ">=5"
  },
  "scripts": {
    "build": "build-figma-plugin --typecheck --minify",
    "watch": "build-figma-plugin --typecheck --watch",
    "version:patch": "./bump-version.sh patch",
    "version:minor": "./bump-version.sh minor",
    "version:major": "./bump-version.sh major"
  },
  "figma-plugin": {
    "editorType": [
      "figma"
    ],
    "id": "batch-rename-layers",
    "name": "Batch Rename",
    "main": "src/main.ts",
    "ui": "src/ui.tsx",
    "networkAccess": {
      "allowedDomains": ["none"]
    }
  }
}
